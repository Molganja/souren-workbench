{
  "name": "souren-workbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --no-warnings server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node --no-warnings server/index.js",
    "check": "npm run build",
    "doctor": "node --no-warnings scripts/system-check.js",
    "test:e2e": "node --no-warnings scripts/e2e-smoke.js",
    "verify": "node --no-warnings scripts/verify-release.js",
    "verify:consult": "node --no-warnings scripts/verify-release.js --consult"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rollup": "npm:@rollup/wasm-node@^4.61.0",
    "vite": "^7.2.4"
  }
}
