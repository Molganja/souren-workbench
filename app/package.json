{
  "name": "souren-workbench",
  "version": "1.0.0",
  "description": "素人种草运营工作台本地客户端",
  "author": "Molganja",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --no-warnings server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "client": "npm run build && electron electron/main.cjs",
    "client:check": "node --no-warnings scripts/desktop-check.js",
    "client:mac": "npm run build && electron-builder --mac dir",
    "client:package:check": "node --no-warnings scripts/desktop-package-smoke.js",
    "client:verify": "npm run client:mac && npm run client:package:check",
    "client:dist": "npm run build && electron-builder --mac dmg",
    "start": "node --no-warnings server/index.js",
    "check": "npm run build",
    "doctor": "node --no-warnings scripts/system-check.js",
    "test:e2e": "node --no-warnings scripts/e2e-smoke.js",
    "collect:douyin": "node --no-warnings scripts/douyin-chrome-collector.js",
    "collect:douyin:self-test": "node --no-warnings scripts/douyin-chrome-collector.js --self-test",
    "verify": "node --no-warnings scripts/verify-release.js",
    "verify:github": "node --no-warnings scripts/verify-release.js --strict-github"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rollup": "npm:@rollup/wasm-node@^4.61.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.souren.workbench",
    "productName": "素人种草运营工作台",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      ".env.example",
      "!node_modules/electron-builder/**/*",
      "!node_modules/electron/**/*",
      "!release/**/*",
      "!src/**/*",
      "!scripts/**/*",
      "!samples/**/*",
      "!*.log",
      "!.env"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.business"
    }
  }
}
